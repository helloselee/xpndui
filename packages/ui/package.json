{
  "name": "@xpndui/ui",
  "version": "0.1.1",
  "description": "xpnd design system — components, tokens, and utilities on shadcn/Base UI.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helloselee/xpndui.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/helloselee/xpndui/tree/main/packages/ui",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json && cp -r src/styles dist/styles",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tokens.css": "./src/styles/tokens.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./tokens.css": "./dist/styles/tokens.css"
    }
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.25.0",
    "next-themes": "^0.4.6",
    "shadcn": "^4.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "@base-ui/react": ">=1",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  }
}
